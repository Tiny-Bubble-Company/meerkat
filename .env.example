# Example environment variables for Meerkat

# Run Solid Queue workers inside Puma (monitors + webhooks). bin/dev sets this by default.
# Alternatively run `bin/jobs` in a second terminal alongside `bin/rails server`.
SOLID_QUEUE_IN_PUMA=1

# Optional platform LLM key for local development only (BYOK customers use dashboard settings).
# Production cloud: customers bring their own keys; do not rely on this.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
MEERKAT_DEFAULT_LLM_PROVIDER=anthropic

# Public URLs for deploy buttons and marketing links (optional)
MEERKAT_GITHUB_REPO=https://github.com/Tiny-Bubble-Company/meerkat
MEERKAT_WEBSITE_URL=https://meerkat.dev
MEERKAT_CLOUD_URL=https://meerkat.dev

# Optional agent tuning
MEERKAT_AGENT_MODEL=claude-sonnet-4-20250514
MEERKAT_FAILURE_THRESHOLD=5
MEERKAT_WEBHOOK_TIMEOUT=15
MEERKAT_CORS_ORIGINS=*

# WhatsApp (optional)
MEERKAT_WHATSAPP_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
