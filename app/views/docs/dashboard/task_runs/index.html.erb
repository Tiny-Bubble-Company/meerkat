<h1>Runs</h1>
<p class="lede">Execution history for all tasks in your account.</p>

<%= form_with url: docs_dashboard_task_runs_path, method: :get, class: "dash-filters" do %>
  <%= select_tag :status, options_for_select([["All statuses", ""]] + TaskRun::STATUSES.map { |s| [s, s] }, params[:status]), class: "form-input" %>
  <%= submit_tag "Filter", class: "btn btn-ghost" %>
<% end %>

<div class="dash-table-wrap">
  <table>
    <thead>
      <tr>
        <th>ID</th>
        <th>Task</th>
        <th>Status</th>
        <th>Change</th>
        <th>Started</th>
        <th>Finished</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @runs.each do |run| %>
        <tr>
          <td><code>#<%= run.id %></code></td>
          <td class="dash-truncate">
            <%= link_to run.task.description, docs_dashboard_task_path(run.task, tab: "runs") %>
          </td>
          <td><%= dashboard_status_badge(run.status) %></td>
          <td><%= run.change_detected ? "yes" : "no" %></td>
          <td><%= dashboard_timestamp(run.started_at) %></td>
          <td><%= dashboard_timestamp(run.finished_at) %></td>
          <td><%= link_to "View", docs_dashboard_task_run_path(run) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<% if @runs.empty? %>
  <p>No runs yet.</p>
<% end %>

<%= dashboard_pagination(@page, @per, @total) %>

<p><%= link_to "← Tasks", docs_dashboard_tasks_path %></p>
