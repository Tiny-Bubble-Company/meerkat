<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= content_for?(:title) ? yield(:title) : "Docs — Meerkat" %></title>
    <link rel="icon" href="/marketing/meerkat-logo.png" type="image/png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <%= render "shared/theme" %>
    <style>
      .docs-shell {
        display: grid;
        grid-template-columns: 240px 1fr;
        min-height: 100vh;
      }

      @media (max-width: 768px) {
        .docs-shell { grid-template-columns: 1fr; }
        .docs-sidebar { border-bottom: 1px solid var(--border); }
      }

      .docs-main {
        display: flex;
        flex-direction: column;
        min-width: 0;
        min-height: 100vh;
      }

      .docs-topbar {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        padding: 0.875rem 3rem;
        border-bottom: 1px solid var(--border);
        background: var(--bg);
        position: sticky;
        top: 0;
        z-index: 20;
      }

      @media (max-width: 768px) {
        .docs-topbar { padding: 0.875rem 1.5rem; }
      }

      .docs-sidebar {
        background: var(--surface);
        border-right: 1px solid var(--border);
        padding: 1.5rem 0;
        position: sticky;
        top: 0;
        height: 100vh;
        overflow-y: auto;
      }

      .sidebar-logo {
        display: block;
        padding: 0 1.25rem 1.5rem;
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--text);
        text-decoration: none;
        letter-spacing: -0.03em;
      }

      .sidebar-logo em { color: var(--accent); font-style: normal; }

      /* sidebar-brand styles live in shared/theme */

      .sidebar-group {
        padding: 0.5rem 0.75rem;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--muted);
      }

      .nav-link {
        display: block;
        padding: 0.65rem 1.25rem;
        color: var(--muted);
        font-size: 1.0625rem;
        text-decoration: none;
        border-left: 3px solid transparent;
      }

      .nav-link:hover { color: var(--text); background: var(--surface-2); text-decoration: none; }
      .nav-link.active { color: var(--accent); border-left-color: var(--accent); background: var(--surface-2); }

      .docs-content {
        flex: 1;
        min-width: 0;
        padding: 2.5rem 3rem 4rem;
        max-width: 920px;
      }

      .docs-page {
        display: flex;
        flex: 1;
        align-items: flex-start;
        min-width: 0;
      }

      .docs-page-index {
        width: 220px;
        flex-shrink: 0;
        padding: 2.5rem 2rem 4rem 0;
        position: sticky;
        top: 3.75rem;
        align-self: flex-start;
        max-height: calc(100vh - 4.5rem);
        overflow-y: auto;
      }

      .docs-page-index-heading {
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--muted);
        margin: 0 0 0.85rem;
      }

      .docs-page-index-list {
        list-style: none;
        margin: 0;
        padding: 0;
        border-left: 1px solid var(--border);
      }

      .docs-page-index-link {
        display: block;
        padding: 0.35rem 0 0.35rem 0.85rem;
        margin-left: -1px;
        border-left: 2px solid transparent;
        color: var(--muted);
        font-size: 0.875rem;
        line-height: 1.4;
        text-decoration: none;
        transition: color 0.15s ease, border-color 0.15s ease;
      }

      .docs-page-index-link:hover {
        color: var(--text);
        text-decoration: none;
      }

      .docs-page-index-link.is-active {
        color: var(--accent);
        border-left-color: var(--accent);
        font-weight: 500;
      }

      @media (max-width: 1180px) {
        .docs-page-index { display: none; }
      }

      @media (max-width: 768px) {
        .docs-content { padding: 1.5rem; }
      }

      .docs-content h1 {
        font-size: var(--font-xl);
        font-weight: 700;
        letter-spacing: -0.02em;
        margin-bottom: 0.75rem;
      }

      .docs-content .lede {
        font-size: var(--font-lg);
        color: var(--muted);
        margin-bottom: 2rem;
        max-width: 55ch;
      }

      .docs-content h2 {
        font-size: 1.125rem;
        font-weight: 600;
        margin: 2rem 0 0.75rem;
        color: var(--text);
      }

      .docs-content p {
        color: var(--muted);
        margin-bottom: 1rem;
        font-size: 1.0625rem;
      }

      .endpoint {
        display: flex;
        gap: 0.75rem;
        align-items: baseline;
        padding: 0.65rem 0;
        border-bottom: 1px solid var(--border);
        font-size: 1rem;
      }

      .method {
        font-family: var(--mono);
        font-size: 0.8125rem;
        font-weight: 600;
        padding: 0.2rem 0.5rem;
        border-radius: 4px;
        min-width: 3.5rem;
        text-align: center;
      }

      .method-get { background: #1e3a5f; color: #93c5fd; }
      .method-post { background: #14532d; color: #86efac; }
      .method-put { background: #312e81; color: #c4b5fd; }
      .method-patch { background: #422006; color: #fcd34d; }
      .method-delete { background: #450a0a; color: #fca5a5; }

      .api-endpoint,
      .api-object {
        padding: 2rem 0;
        border-top: 1px solid var(--border);
        scroll-margin-top: 5rem;
      }

      .api-endpoint-title {
        font-size: 1.375rem;
        font-weight: 600;
        letter-spacing: -0.02em;
        margin: 0 0 1rem;
        color: var(--text);
      }

      .api-endpoint-header {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-wrap: wrap;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 0.85rem 1rem;
        margin-bottom: 1rem;
      }

      .api-path {
        font-family: var(--mono);
        font-size: 0.9375rem;
        color: var(--text);
        word-break: break-all;
      }

      .api-endpoint-desc {
        color: var(--muted);
        font-size: 1rem;
        line-height: 1.6;
        margin-bottom: 1.25rem;
        max-width: 65ch;
      }

      .api-subheading {
        font-size: 0.8125rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--muted);
        margin: 1.5rem 0 0.75rem;
      }

      .api-table-wrap {
        overflow-x: auto;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        margin-bottom: 0.5rem;
      }

      .api-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.9375rem;
      }

      .api-table th,
      .api-table td {
        padding: 0.65rem 0.85rem;
        text-align: left;
        border-bottom: 1px solid var(--border);
        vertical-align: top;
      }

      .api-table th {
        background: var(--surface);
        color: var(--muted);
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }

      .api-table tr:last-child td { border-bottom: none; }

      .api-table td code {
        font-size: 0.8125rem;
        background: var(--surface-2);
        padding: 0.1rem 0.35rem;
        border-radius: 4px;
      }

      .api-code {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 1rem 1.15rem;
        overflow-x: auto;
        margin: 0 0 1rem;
        font-family: var(--mono);
        font-size: 0.8125rem;
        line-height: 1.55;
        color: #e2e8f0;
      }

      .api-code code { background: none; padding: 0; }

      .api-response { margin-bottom: 1.25rem; }

      .api-response-label {
        display: flex;
        align-items: center;
        gap: 0.65rem;
        margin-bottom: 0.5rem;
        font-size: 0.9375rem;
        color: var(--muted);
      }

      .api-status {
        font-family: var(--mono);
        font-size: 0.75rem;
        font-weight: 600;
        padding: 0.2rem 0.5rem;
        border-radius: 4px;
        white-space: nowrap;
      }

      .api-status-2xx { background: #14532d; color: #86efac; }
      .api-status-4xx { background: #450a0a; color: #fca5a5; }

      .api-footer-links {
        margin-top: 2rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--border);
      }
    </style>
  </head>
  <body>
    <div class="docs-shell">
      <aside class="docs-sidebar">
        <%= render "shared/brand_logo", url: meerkat_website_url, variant: "sidebar" %>

        <div class="sidebar-group">Dashboard</div>
        <%= docs_nav_link("api-keys") %>

        <div class="sidebar-group">API</div>
        <%= docs_nav_link("quickstart") %>
        <%= docs_nav_link("authentication") %>
        <%= docs_nav_link("task-types") %>
        <%= docs_nav_link("tasks") %>
        <%= docs_nav_link("webhooks") %>
        <%= docs_nav_link("reference") %>
      </aside>

      <div class="docs-main">
        <header class="docs-topbar">
          <%= render "shared/user_menu" %>
        </header>

        <div class="docs-page">
          <main class="docs-content">
            <% if flash[:notice] %><div class="flash flash-notice"><%= flash[:notice] %></div><% end %>
            <% if flash[:alert] %><div class="flash flash-alert"><%= flash[:alert] %></div><% end %>

            <%= yield %>
          </main>

          <% if content_for?(:docs_page_index) %>
            <aside class="docs-page-index">
              <%= yield :docs_page_index %>
            </aside>
          <% end %>
        </div>
      </div>
    </div>

    <script>
      (function () {
        document.querySelectorAll("[data-user-menu]").forEach(function (menu) {
          var toggle = menu.querySelector("[data-user-menu-toggle]");
          var panel = menu.querySelector("[data-user-menu-panel]");
          if (!toggle || !panel) return;

          toggle.addEventListener("click", function (e) {
            e.stopPropagation();
            var open = panel.classList.toggle("hidden") === false;
            toggle.setAttribute("aria-expanded", open ? "true" : "false");
          });

          document.addEventListener("click", function (e) {
            if (!menu.contains(e.target)) {
              panel.classList.add("hidden");
              toggle.setAttribute("aria-expanded", "false");
            }
          });

          document.addEventListener("keydown", function (e) {
            if (e.key === "Escape") {
              panel.classList.add("hidden");
              toggle.setAttribute("aria-expanded", "false");
            }
          });
        });

        document.querySelectorAll("[data-copy]").forEach(btn => {
          btn.addEventListener("click", () => {
            navigator.clipboard.writeText(btn.dataset.copy);
            btn.textContent = "Copied";
            setTimeout(() => { btn.textContent = "Copy"; }, 2000);
          });
        });

        var pageIndex = document.querySelector("[data-docs-page-index]");
        if (pageIndex) {
          var indexLinks = pageIndex.querySelectorAll("[data-docs-page-index-link]");
          var sectionIds = Array.from(indexLinks).map(function (link) {
            return link.getAttribute("data-docs-page-index-link");
          });
          var sections = sectionIds.map(function (id) {
            return document.getElementById(id);
          }).filter(Boolean);

          function setActiveIndex(id) {
            indexLinks.forEach(function (link) {
              link.classList.toggle("is-active", link.getAttribute("data-docs-page-index-link") === id);
            });
          }

          indexLinks.forEach(function (link) {
            link.addEventListener("click", function (e) {
              e.preventDefault();
              var id = link.getAttribute("data-docs-page-index-link");
              var target = document.getElementById(id);
              if (target) {
                target.scrollIntoView({ behavior: "smooth", block: "start" });
                history.replaceState(null, "", "#" + id);
                setActiveIndex(id);
              }
            });
          });

          if ("IntersectionObserver" in window && sections.length) {
            var observer = new IntersectionObserver(function (entries) {
              var visible = entries
                .filter(function (entry) { return entry.isIntersecting; })
                .sort(function (a, b) { return b.intersectionRatio - a.intersectionRatio; });
              if (visible.length) setActiveIndex(visible[0].target.id);
            }, { rootMargin: "-20% 0px -65% 0px", threshold: [0, 0.25, 0.5, 1] });

            sections.forEach(function (section) { observer.observe(section); });
          }

          var hash = window.location.hash.replace("#", "");
          if (hash && sectionIds.indexOf(hash) !== -1) setActiveIndex(hash);
        }
      })();
    </script>
  </body>
</html>
