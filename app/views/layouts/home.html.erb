<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= content_for?(:title) ? yield(:title) : "Meerkat — Open source async agent task API with webhooks" %></title>
    <% if content_for?(:meta_description) %>
      <meta name="description" content="<%= yield(:meta_description) %>">
    <% end %>
    <% if content_for?(:meta_keywords) %>
      <meta name="keywords" content="<%= yield(:meta_keywords) %>">
    <% end %>
    <% if content_for?(:og_title) %>
      <meta property="og:title" content="<%= yield(:og_title) %>">
    <% end %>
    <% if content_for?(:og_description) %>
      <meta property="og:description" content="<%= yield(:og_description) %>">
    <% end %>
    <% if content_for?(:og_type) %>
      <meta property="og:type" content="<%= yield(:og_type) %>">
    <% end %>
    <meta property="og:url" content="<%= content_for?(:canonical_url) ? yield(:canonical_url) : marketing_canonical_url %>">
    <link rel="canonical" href="<%= content_for?(:canonical_url) ? yield(:canonical_url) : marketing_canonical_url %>">
    <link rel="icon" href="/marketing/meerkat-logo.png" type="image/png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500;600&family=Work+Sans:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/marketing/styles.css">
    <%= render "shared/form_styles" %>
    <%= yield :head %>
  </head>
  <body class="min-h-screen bg-background text-foreground overflow-x-hidden">
    <% if (msg = flash[:notice] || flash.now[:notice]) %>
      <div class="border-b border-primary/30 bg-primary/10 px-6 py-3 text-center font-mono text-[13px] text-foreground"><%= msg %></div>
    <% end %>
    <% if (msg = flash[:alert] || flash.now[:alert]) %>
      <div class="border-b border-destructive/30 bg-destructive/10 px-6 py-3 text-center font-mono text-[13px] text-foreground"><%= msg %></div>
    <% end %>

    <%= yield %>

    <script>
      (function () {
        var toggle = document.querySelector("[data-marketing-nav-toggle]");
        var mobileNav = document.getElementById("mobile-nav");
        if (toggle && mobileNav) {
          toggle.addEventListener("click", function () {
            mobileNav.classList.toggle("hidden");
            var open = !mobileNav.classList.contains("hidden");
            toggle.setAttribute("aria-expanded", open ? "true" : "false");
          });
        }

        document.querySelectorAll("[data-use-cases-toggle]").forEach(function (btn) {
          var menu = btn.parentElement.querySelector("[data-use-cases-menu]");
          if (!menu) return;
          btn.addEventListener("click", function () {
            var open = menu.classList.toggle("hidden") === false;
            btn.setAttribute("aria-expanded", open ? "true" : "false");
          });
          btn.parentElement.addEventListener("mouseenter", function () {
            menu.classList.remove("hidden");
            btn.setAttribute("aria-expanded", "true");
          });
          btn.parentElement.addEventListener("mouseleave", function () {
            menu.classList.add("hidden");
            btn.setAttribute("aria-expanded", "false");
          });
        });

        document.addEventListener("click", function (e) {
          document.querySelectorAll("[data-use-cases-menu]").forEach(function (menu) {
            if (!menu.parentElement.contains(e.target)) menu.classList.add("hidden");
          });
        });

        var typeEl = document.querySelector("[data-typewriter]");
        if (typeEl) {
          var full = typeEl.dataset.typewriter || "";
          var i = 0;
          var id = setInterval(function () {
            i += 1;
            typeEl.textContent = full.slice(0, i);
            if (i >= full.length) clearInterval(id);
          }, 70);
        }
      })();
    </script>
  </body>
</html>
