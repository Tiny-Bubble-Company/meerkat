<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= content_for?(:title) ? yield(:title) : "Meerkat" %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <%= render "shared/theme" %>
    <style>
      .home-nav {
        max-width: 960px;
        margin: 0 auto;
        padding: 1.5rem 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .logo {
        font-size: 1.35rem;
        font-weight: 700;
        color: var(--text);
        text-decoration: none;
        letter-spacing: -0.03em;
      }

      .logo em { color: var(--accent); font-style: normal; }

      .home-nav-links { display: flex; gap: 1.25rem; align-items: center; }
      .home-nav-links a { color: var(--muted); font-size: 1rem; text-decoration: none; }
      .home-nav-links a:hover { color: var(--text); }

      .home-main {
        max-width: 980px;
        margin: 0 auto;
        padding: 3rem 2rem 5rem;
      }

      .eyebrow {
        font-size: 1rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--accent);
        margin-bottom: 1rem;
      }

      .hero h1 {
        font-size: var(--font-3xl);
        font-weight: 700;
        line-height: 1.1;
        letter-spacing: -0.03em;
        margin-bottom: 1.5rem;
        max-width: 22ch;
      }

      .hero-lead,
      .section-body {
        font-size: var(--font-lg);
        color: var(--muted);
        max-width: 62ch;
        margin-bottom: 1.25rem;
        line-height: 1.6;
      }

      .section-body strong { color: var(--text); font-weight: 600; }

      .home-section {
        margin-bottom: 4rem;
      }

      .home-section h2 {
        font-size: var(--font-xl);
        font-weight: 700;
        letter-spacing: -0.02em;
        margin-bottom: 1.25rem;
        color: var(--text);
      }

      .cta-row { display: flex; flex-wrap: wrap; gap: 1rem; margin-bottom: 1rem; }

      .pill-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 1rem;
        margin: 0;
      }

      .pill-row.two-col { grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); }
      .pill-row.three-col { grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); }
      .pill-row.four-col { grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); }

      .deploy-section { padding: 2rem; background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); }
      .deploy-row { display: flex; flex-wrap: wrap; gap: 1rem; margin-bottom: 1rem; }

      .deploy-btn {
        display: flex;
        flex-direction: column;
        gap: 0.15rem;
        padding: 1rem 1.5rem;
        border-radius: var(--radius);
        text-decoration: none;
        border: 1px solid var(--border);
        min-width: 140px;
        transition: border-color 0.15s, transform 0.15s;
      }

      .deploy-btn:hover { transform: translateY(-2px); border-color: var(--accent-dim); }
      .deploy-btn-label { font-size: 0.8125rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.06em; }
      .deploy-btn strong { font-size: 1.125rem; color: var(--text); }

      .deploy-btn--render { background: #0d1117; border-color: #30363d; }
      .deploy-btn--render strong { color: #fff; }
      .deploy-btn--fly { background: #4f46e5; border-color: #6366f1; }
      .deploy-btn--fly strong, .deploy-btn--fly .deploy-btn-label { color: #fff; }
      .deploy-btn--docker { background: #1e3a5f; border-color: #2563eb; }
      .deploy-btn--docker strong { color: #93c5fd; }

      .compare-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1.25rem;
      }

      .compare-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 1.5rem;
      }

      .compare-card--highlight { border-color: var(--accent-dim); background: var(--surface-2); }

      .compare-card h3 {
        font-size: 1.125rem;
        font-weight: 700;
        margin-bottom: 1rem;
        color: var(--text);
      }

      .compare-card ul {
        list-style: none;
        padding: 0;
        margin: 0 0 1.25rem;
      }

      .compare-card li {
        color: var(--muted);
        font-size: 1rem;
        padding: 0.35rem 0;
        padding-left: 1.25rem;
        position: relative;
      }

      .compare-card li::before {
        content: "✓";
        position: absolute;
        left: 0;
        color: #86efac;
        font-size: 0.875rem;
      }

      .compare-link {
        color: var(--accent);
        font-size: 1rem;
        font-weight: 600;
        text-decoration: none;
      }

      .compare-link:hover { text-decoration: underline; }

      .pill code { font-size: 0.875rem; color: var(--accent); }

      .pill {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 1.35rem 1.5rem;
      }

      .pill strong {
        display: block;
        font-size: 1.1875rem;
        margin-bottom: 0.5rem;
        color: var(--text);
      }

      .pill span { color: var(--muted); font-size: 1.0625rem; line-height: 1.55; }

      .api-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 1rem;
        margin-bottom: 1.25rem;
      }

      .api-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 1.25rem 1.35rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
      }

      .api-card strong {
        font-size: 1.0625rem;
        color: var(--text);
        font-family: var(--mono);
        font-weight: 500;
      }

      .api-card span { color: var(--muted); font-size: 1rem; line-height: 1.5; }

      .method {
        display: inline-block;
        font-family: var(--mono);
        font-size: 0.75rem;
        font-weight: 600;
        padding: 0.2rem 0.5rem;
        border-radius: 4px;
        width: fit-content;
      }

      .method-get { background: #1e3a5f; color: #93c5fd; }
      .method-post { background: #14532d; color: #86efac; }

      .muted-link a { color: var(--muted); font-size: 1.0625rem; }
      .muted-link a:hover { color: var(--accent); }

      .cta-section { padding-top: 1rem; border-top: 1px solid var(--border); }

      @media (max-width: 640px) {
        .hero h1 { font-size: var(--font-2xl); }
      }

      .signup-box {
        max-width: 420px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 2rem;
      }

      .signup-box h1 { font-size: var(--font-xl); margin-bottom: 0.5rem; }
      .signup-box .sub { color: var(--muted); margin-bottom: 1.5rem; font-size: 1.0625rem; }

      .field { margin-bottom: 1.25rem; }

      .home-footer {
        max-width: 960px;
        margin: 0 auto;
        padding: 2rem;
        color: var(--muted);
        font-size: 0.9375rem;
        border-top: 1px solid var(--border);
      }
    </style>
  </head>
  <body>
    <nav class="home-nav">
      <%= link_to root_path, class: "logo" do %>Meer<em>kat</em><% end %>
      <div class="home-nav-links">
        <%= link_to "Docs", docs_path %>
        <%= link_to "GitHub", github_repo_url, target: "_blank", rel: "noopener" %>
        <% if customer_signed_in? %>
          <% if current_customer.onboarding_completed? %>
            <%= link_to "API Keys", docs_section_path("api-keys") %>
          <% else %>
            <%= link_to "Continue setup", onboarding_step_path(session[:onboarding_step].presence || "api-key") %>
          <% end %>
          <%= button_to "Sign out", logout_path, method: :delete, class: "btn btn-ghost", style: "padding:0.5rem 1rem;font-size:0.9375rem" %>
        <% else %>
          <%= link_to "Sign up", signup_path, class: "btn btn-primary", style: "padding:0.5rem 1rem;font-size:0.9375rem" %>
        <% end %>
      </div>
    </nav>

    <% if (msg = flash[:notice] || flash.now[:notice]) %><div class="home-main"><div class="flash flash-notice"><%= msg %></div></div><% end %>
    <% if (msg = flash[:alert] || flash.now[:alert]) %><div class="home-main"><div class="flash flash-alert"><%= msg %></div></div><% end %>

    <%= yield %>

    <footer class="home-footer">
      Open source agentic task API ·
      <%= link_to "GitHub", github_repo_url, target: "_blank", rel: "noopener" %> ·
      <%= link_to "Meerkat Cloud", meerkat_cloud_url, target: "_blank", rel: "noopener" %>
    </footer>

    <script>
      document.querySelectorAll("[data-copy]").forEach(btn => {
        btn.addEventListener("click", () => {
          navigator.clipboard.writeText(btn.dataset.copy);
          btn.textContent = "Copied";
          setTimeout(() => { btn.textContent = "Copy"; }, 2000);
        });
      });
    </script>
  </body>
</html>
