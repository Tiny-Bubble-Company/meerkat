<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="csrf-token" content="<%= form_authenticity_token %>">
    <title><%= content_for?(:title) ? yield(:title) : "Getting started — Meerkat" %></title>
    <link rel="icon" href="/marketing/meerkat-logo.png" type="image/png">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <%= render "shared/theme" %>
    <style>
      .onboarding-shell {
        min-height: 100vh;
        max-width: 720px;
        margin: 0 auto;
        padding: 2rem 1.5rem 4rem;
      }

      .onboarding-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2.5rem;
      }

      .onboarding-logo {
        font-size: 1.35rem;
        font-weight: 700;
        color: var(--text);
        text-decoration: none;
        letter-spacing: -0.03em;
      }

      .onboarding-logo em { color: var(--accent); font-style: normal; }

      .onboarding-progress {
        display: flex;
        gap: 0.5rem;
        list-style: none;
        margin-bottom: 2.5rem;
        flex-wrap: wrap;
      }

      .onboarding-step {
        flex: 1;
        min-width: 100px;
        text-align: center;
        padding: 0.65rem 0.5rem;
        border-radius: 8px;
        font-size: 0.9375rem;
        color: var(--muted);
        background: var(--surface);
        border: 1px solid var(--border);
      }

      .onboarding-step--current {
        color: var(--accent);
        border-color: var(--accent-dim);
        background: var(--surface-2);
        font-weight: 600;
      }

      .onboarding-step--done {
        color: #86efac;
        border-color: #166534;
      }

      .onboarding-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 2rem;
      }

      .onboarding-card h1 {
        font-size: var(--font-xl);
        font-weight: 700;
        letter-spacing: -0.02em;
        margin-bottom: 0.75rem;
      }

      .onboarding-card .lede {
        font-size: var(--font-lg);
        color: var(--muted);
        margin-bottom: 1.75rem;
        max-width: 50ch;
      }

      .warning-banner {
        background: #422006;
        border: 1px solid var(--accent-dim);
        border-radius: var(--radius);
        padding: 1rem 1.25rem;
        margin-bottom: 1.25rem;
        color: #fde68a;
        font-size: 1.0625rem;
      }

      .endpoint-row {
        display: flex;
        gap: 0.75rem;
        align-items: center;
        margin-bottom: 1.25rem;
        font-size: 1rem;
      }

      .field { margin-bottom: 1.25rem; }

      .field-hint {
        color: var(--muted);
        font-size: 0.9375rem;
        margin-top: 0.35rem;
      }

      .actions {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
        margin-top: 1.75rem;
      }

      .waiting-panel {
        text-align: center;
        padding: 2rem 1.25rem;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
      }

      .waiting-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.25rem;
        margin-top: 1.5rem;
      }

      @media (max-width: 640px) {
        .waiting-grid { grid-template-columns: 1fr; }
      }

      .panel-label {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--muted);
        margin-bottom: 1rem;
        text-align: left;
      }

      .waiting-panel--run .panel-label,
      .waiting-panel--run .run-status-text { text-align: center; }
      .waiting-panel--run .panel-label { margin-bottom: 0.5rem; }

      .webhook-inbox {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 1.25rem;
        min-height: 220px;
      }

      .webhook-inbox--received {
        border-color: var(--accent-dim);
        box-shadow: 0 0 0 1px rgba(251, 191, 36, 0.12);
      }

      .webhook-inbox--success { margin: 1.5rem 0; }

      .webhook-inbox-waiting {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 2rem 1rem;
        gap: 1rem;
      }

      .webhook-pulse {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        background: var(--accent);
        animation: webhook-pulse 1.4s ease-in-out infinite;
      }

      @keyframes webhook-pulse {
        0%, 100% { opacity: 0.35; transform: scale(0.85); }
        50% { opacity: 1; transform: scale(1.15); }
      }

      .webhook-payload {
        background: var(--surface-2);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 1rem;
        font-family: var(--mono);
        font-size: 0.8125rem;
        line-height: 1.55;
        overflow-x: auto;
        max-height: 320px;
        margin: 0;
        text-align: left;
        white-space: pre-wrap;
        word-break: break-word;
      }

      .form-input-readonly {
        opacity: 0.85;
        cursor: default;
        font-family: var(--mono);
        font-size: 0.875rem;
      }

      .spinner {
        width: 48px;
        height: 48px;
        border: 3px solid var(--border);
        border-top-color: var(--accent);
        border-radius: 50%;
        margin: 0 auto 1.25rem;
        animation: spin 0.9s linear infinite;
      }

      @keyframes spin { to { transform: rotate(360deg); } }

      .success-panel {
        text-align: center;
        padding: 2rem 1rem;
      }

      .success-icon {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        background: #14532d;
        color: #86efac;
        font-size: 2rem;
        line-height: 64px;
        margin: 0 auto 1.25rem;
      }

      .success-panel.failed .success-icon {
        background: #450a0a;
        color: #fca5a5;
      }

      .run-status-text {
        font-size: var(--font-lg);
        color: var(--muted);
        margin-bottom: 0.5rem;
      }

      .hidden { display: none; }
    </style>
  </head>
  <body>
    <div class="onboarding-shell">
      <header class="onboarding-header">
        <%= render "shared/brand_logo", url: meerkat_website_url, variant: "inline" %>
        <span style="color:var(--muted);font-size:0.9375rem">Setup</span>
      </header>

      <%= onboarding_progress(@step) if @step %>

      <% if flash[:notice] %><div class="flash flash-notice"><%= flash[:notice] %></div><% end %>
      <% if flash[:alert] %><div class="flash flash-alert"><%= flash[:alert] %></div><% end %>

      <div class="onboarding-card">
        <%= yield %>
      </div>
    </div>

    <script>
      document.querySelectorAll("[data-copy]").forEach(btn => {
        btn.addEventListener("click", () => {
          navigator.clipboard.writeText(btn.dataset.copy);
          btn.textContent = "Copied";
          setTimeout(() => { btn.textContent = "Copy key"; }, 2000);
        });
      });
    </script>
  </body>
</html>
