<% content_for :title, "Create task — Meerkat" %>

<h1>Create your first task</h1>
<p class="lede">This is the same call as <code>POST /api/v1/tasks</code>. We'll use a one-off task for a quick first run.</p>

<div class="endpoint-row">
  <span class="method method-post">POST</span>
  <code><%= api_base_url %>/tasks</code>
</div>

<pre><code>{
  "task": {
    "task_type": "one_off",
    "description": "<%= @sample_payload[:description] %>",
    "input_params": { "url": "<%= @sample_payload[:input_params][:url] %>" },
    "output_webhook": "https://your-app.com/hook"
  }
}</code></pre>

<%= form_with url: onboarding_create_task_path, scope: :task, method: :post do |f| %>
  <div class="field">
    <%= f.label :description, "Description" %>
    <%= f.text_field :description, value: @sample_payload[:description], required: true %>
  </div>
  <div class="field">
    <%= f.label :url, "URL to fetch" %>
    <%= f.text_field :url, value: @sample_payload[:input_params][:url], required: true, placeholder: "https://example.com" %>
    <p class="field-hint">Passed as <code>input_params.url</code></p>
  </div>
  <div class="field">
    <%= f.label :output_webhook, "Webhook URL" %>
    <%= f.text_field :output_webhook, required: true, placeholder: "https://webhook.site/your-id" %>
    <p class="field-hint">Required — Meerkat POSTs results here</p>
  </div>
  <div class="actions">
    <%= f.submit "Create task", class: "btn btn-primary" %>
  </div>
<% end %>
