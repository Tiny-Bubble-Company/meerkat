</section>

<section class="border-b border-border bg-background py-28">
  <div class="mx-auto max-w-7xl px-6">
    <div class="max-w-2xl">
      <p class="font-mono text-[11px] uppercase tracking-[0.3em] text-primary">02 · Lifecycle</p>
      <h2 class="mt-6 font-serif text-5xl leading-[1.05] tracking-tight">
        From <span class="italic">cURL</span> to webhook. Four hops.
      </h2>
    </div>
    <div class="mt-16 grid gap-px overflow-hidden rounded-2xl border border-border bg-border md:grid-cols-2 lg:grid-cols-4">
      <% [
        ["1", "Register", "POST /api/v1/tasks\n  description: \"watch URL\"\n  input_params: {...}\n  output_webhook: \"/hook\""],
        ["2", "Connect LLM", "providers:\n  anthropic | openai\n  openrouter | grok\nkey: encrypted at rest"],
        ["3", "Run", "agent.execute()\n→ on schedule\n→ on demand\n→ change detection"],
        ["4", "Webhook", "POST your-app.com/hook\n  signed: hmac-sha256\n  retries: exponential\n  status: 200 ✓"]
      ].each do |num, title, code| %>
        <div class="group relative bg-card p-8 transition hover:bg-card/60">
          <div class="flex items-center justify-between">
            <span class="font-serif text-6xl italic text-primary/40 transition group-hover:text-primary/70"><%= num %></span>
            <span class="font-mono text-[11px] uppercase tracking-widest text-muted-foreground">step</span>
          </div>
          <h3 class="mt-4 font-serif text-2xl"><%= title %></h3>
          <pre class="mt-6 whitespace-pre rounded-md border border-border bg-background/60 p-4 font-mono text-[12px] leading-relaxed text-muted-foreground"><%= code %></pre>
        </div>
      <% end %>
    </div>
    <div class="mt-10 flex flex-wrap gap-3">
      <%= link_to "Start onboarding →", marketing_signup_path, marketing_signup_link_options(class: "rounded-md bg-primary px-5 py-3 font-mono text-[12px] font-semibold uppercase tracking-wider text-primary-foreground transition hover:brightness-110") %>
      <%= link_to "LLM provider setup", marketing_docs_section_path("llm-provider"), class: "rounded-md border border-border bg-card px-5 py-3 font-mono text-[12px] uppercase tracking-wider transition hover:border-primary/40" %>
    </div>
  </div>
</section>

<%= render "marketing/home/flow_viz" %>

