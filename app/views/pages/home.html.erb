              <div class="grid grid-cols-[80px_1fr] items-baseline gap-6 border-b border-border/60 pb-5 last:border-0 last:pb-0">
                <span class="text-[11px] uppercase tracking-widest text-primary"><%= key %></span>
                <div>
                  <div class="text-foreground"><%= value %></div>
                  <div class="mt-1 font-sans text-[13px] text-muted-foreground"><%= desc %></div>
                </div>
              </div>
