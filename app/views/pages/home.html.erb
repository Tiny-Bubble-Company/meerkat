        ["one_off", "Ad-hoc fetches without standing up a scheduler.", "Fire a single task for research, scraping, or extraction. Marked complete after the webhook lands.", 'task_type: "one_off" · status: "succeeded"', agent_webhooks_path]
      ].each do |tag, title, desc, meta, path| %>
