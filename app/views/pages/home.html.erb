<section class="border-b border-border py-28">
  <div class="mx-auto max-w-7xl px-6">
    <div class="grid gap-16 lg:grid-cols-[1fr_1.2fr] lg:gap-24">
      <div>
        <p class="font-mono text-[11px] uppercase tracking-[0.3em] text-primary">01 · The primitive</p>
