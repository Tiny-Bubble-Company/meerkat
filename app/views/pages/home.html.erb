<% home_faqs = [
  { q: "What is Meerkat?", a: "Meerkat is an open source, webhook-native API for running async LLM agent tasks. You describe a task in English, bring your own LLM key, and Meerkat runs it on a schedule and POSTs results to your webhook." },
  { q: "Is it really open source?", a: "Yes — MIT licensed. Self-host with Docker, Render, or Fly.io, or use Meerkat Cloud. Same REST API either way." },
  { q: "What can I build with it?", a: "Package tracking, website change detection, price monitoring, competitor watching, recurring summaries — anything where an agent should run async and notify your app." },
  { q: "Which LLM providers are supported?", a: "Anthropic, OpenAI, OpenRouter, and Grok. Keys are BYOK and encrypted at rest." }
] %>

<% content_for :title, "Meerkat — Open source async agent task API with webhooks" %>
<% content_for :meta_description, "Open source webhook-native API for async LLM agents. Track packages, monitor URLs, detect website changes — Meerkat runs tasks on a schedule and POSTs signed JSON to your webhook. BYOK, MIT licensed, self-host or Cloud." %>
<% content_for :meta_keywords, "agent task API, webhook API, package tracking API, website change detection API, async LLM agent, open source agent framework, BYOK LLM" %>
<% content_for :og_title, "Meerkat — Open source async agent task API" %>
<% content_for :og_description, "Describe a task in English. Meerkat runs it async on a schedule and POSTs results to your webhook. BYOK keys, MIT licensed." %>
<% content_for :og_type, "website" %>

<% content_for :head do %>
  <script type="application/ld+json">
    <%= {
      "@context" => "https://schema.org",
      "@type" => "SoftwareApplication",
      "name" => "Meerkat",
      "applicationCategory" => "DeveloperApplication",
      "operatingSystem" => "Any",
      "offers" => { "@type" => "Offer", "price" => "0", "priceCurrency" => "USD" },
      "description" => "Open source webhook-native API for async LLM agent tasks. BYOK, MIT licensed."
    }.to_json %>
  </script>
  <script type="application/ld+json"><%= faq_json_ld(home_faqs) %></script>
<% end %>

<%= render "marketing/site_nav" %>

<section class="relative isolate overflow-hidden border-b border-border">
  <div class="absolute inset-0 bg-grid opacity-40"></div>
  <div class="absolute inset-0" style="background: var(--gradient-glow)"></div>
  <div class="pointer-events-none absolute inset-x-0 top-0 h-px gold-rule"></div>

  <div class="relative mx-auto max-w-7xl px-6 pt-20 pb-24 lg:pt-28 lg:pb-32">
    <div class="grid items-center gap-14 lg:grid-cols-[1.05fr_1fr] lg:gap-16">
      <div>
        <div class="mb-8 inline-flex items-center gap-2 border border-border bg-card/60 px-3 py-1.5 font-mono text-[11px] uppercase tracking-[0.2em] text-muted-foreground backdrop-blur">
          <span class="relative flex h-1.5 w-1.5">
            <span class="absolute inline-flex h-full w-full rounded-full bg-primary opacity-75 pulse-ring"></span>
            <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-primary"></span>
          </span>
          Open source · MIT · BYOK · Webhook-native
        </div>

        <h1 class="font-serif text-[clamp(2.25rem,5.5vw,4.25rem)] font-normal leading-[1.05] tracking-[-0.02em] text-balance">
          Describe a task in your own words.
          <span class="italic text-muted-foreground">Meerkat runs it async.</span>
        </h1>

        <p class="mt-7 max-w-xl text-[17px] leading-relaxed text-muted-foreground">
          Open source API for developers who need agents to monitor links, track deliveries,
          and report findings — without building schedulers, webhook plumbing, or LLM tool loops.
          Results <span class="font-mono text-foreground">POST</span> to your endpoint.
        </p>

        <div class="mt-9 flex flex-wrap items-center gap-3">
          <%= link_to marketing_signup_path, marketing_signup_link_options(class: "group inline-flex items-center gap-2 bg-primary px-5 py-3 font-mono text-[13px] font-semibold uppercase tracking-wider text-primary-foreground transition hover:brightness-110 glow-amber") do %>
            <%= customer_signed_in? ? marketing_signup_label : "Sign up free" %>
            <span class="transition group-hover:translate-x-0.5">→</span>
          <% end %>
          <%= link_to "Read the docs", marketing_docs_path, class: "inline-flex items-center gap-2 border border-border bg-card/60 px-5 py-3 font-mono text-[13px] font-semibold uppercase tracking-wider text-foreground transition hover:border-primary/50 hover:bg-card" %>
        </div>
      </div>

      <div class="relative flex flex-col gap-5">
        <div class="absolute -inset-8 -z-10 rounded-3xl" style="background: var(--gradient-glow)"></div>

        <div class="overflow-hidden rounded-xl border border-border bg-card/80 backdrop-blur" style="box-shadow: var(--shadow-card)">
          <div class="flex items-center justify-between border-b border-border bg-background/40 px-4 py-3">
            <span class="font-mono text-[11px] uppercase tracking-widest text-muted-foreground">POST /api/v1/tasks</span>
            <span class="font-mono text-[10px] uppercase tracking-widest text-primary">→ you send</span>
          </div>
          <div class="space-y-3 p-5">
            <% [
              ["task_type", '"recurring"', "one_off or recurring"],
              ["description", '"Monitor DHL and report changes"', "plain english"],
              ["frequency", '"every 2 hours"', "cron or natural language"],
              ["output_webhook", '"https://your-app.com/hook"', "where we POST results"]
            ].each do |key, value, comment| %>
              <div class="grid grid-cols-[140px_1fr] items-baseline gap-3">
                <span class="font-mono text-[12px] text-muted-foreground"><%= key %></span>
                <div class="font-mono text-[12px]">
                  <span class="text-accent"><%= value %></span>
                  <span class="ml-2 text-[11px] text-muted-foreground/60">// <%= comment %></span>
                </div>
              </div>
            <% end %>
          </div>
        </div>

        <div class="flex items-center gap-3 pl-2 font-mono text-[11px] uppercase tracking-[0.25em] text-muted-foreground">
          <span class="h-px flex-1 bg-border"></span>
          <span>↓ ~3.2s</span>
          <span class="h-px flex-1 bg-border"></span>
        </div>

        <div class="overflow-hidden rounded-xl border border-border bg-card/80 backdrop-blur" style="box-shadow: var(--shadow-card)">
          <div class="flex items-center justify-between border-b border-border bg-background/40 px-4 py-3">
            <span class="font-mono text-[11px] uppercase tracking-widest text-muted-foreground">POST /hook</span>
            <span class="font-mono text-[10px] uppercase tracking-widest text-accent">← meerkat</span>
          </div>
          <div class="space-y-3 p-5">
            <% [
              ["status", '"changed"'],
              ["state", '"In transit → Out for delivery"'],
              ["eta", '"2026-06-20T16:40:00Z"'],
              ["location", '"Berlin · DE"']
            ].each do |key, value| %>
              <div class="grid grid-cols-[90px_1fr] items-baseline gap-3">
                <span class="font-mono text-[12px] text-muted-foreground"><%= key %></span>
                <span class="font-mono text-[12px] text-foreground/90"><%= value %></span>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="border-b border-border py-12">
  <div class="mx-auto max-w-7xl px-6">
