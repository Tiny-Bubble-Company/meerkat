<% content_for :title, "Sign up — Meerkat" %>
<% content_for :meta_description, "Create your Meerkat account, get an API key, and start registering async agent tasks with webhook delivery." %>

<%= render "marketing/site_nav" %>

<main class="mx-auto max-w-lg px-6 py-20 lg:py-28">
  <div class="rounded-2xl border border-border bg-card p-8" style="box-shadow: var(--shadow-card)">
    <p class="font-mono text-[11px] uppercase tracking-[0.3em] text-primary">Get started</p>
    <h1 class="mt-4 font-serif text-4xl tracking-tight">Sign up</h1>
    <p class="mt-3 text-[15px] leading-relaxed text-muted-foreground">
      Get an API key, connect your LLM provider, and register your first task in onboarding.
    </p>

    <%= form_with url: signup_path, scope: :customer, class: "form-stack mt-8" do |f| %>
      <div class="field">
        <%= f.label :email, "Email", class: "form-label" %>
        <%= f.email_field :email, required: true, autofocus: true, placeholder: "you@company.com", class: "form-input" %>
      </div>
      <div class="field">
        <%= f.label :name, "Name", class: "form-label" %>
        <%= f.text_field :name, placeholder: "Your name", class: "form-input" %>
      </div>
      <div class="field">
        <%= f.label :company, "Company (optional)", class: "form-label" %>
        <%= f.text_field :company, placeholder: "Acme Inc.", class: "form-input" %>
      </div>
      <%= f.submit "Create account →", class: "form-submit glow-amber" %>
    <% end %>

    <p class="mt-6 text-[14px] text-muted-foreground">
      Already signed up?
      <%= link_to "Continue setup", signup_path, class: "text-primary hover:underline" %>
      · <%= link_to "API keys", docs_section_path("api-keys"), class: "text-primary hover:underline" %>
      · <%= link_to "Docs", docs_path, class: "text-primary hover:underline" %>
    </p>
  </div>
</main>

<%= render "marketing/footer" %>
