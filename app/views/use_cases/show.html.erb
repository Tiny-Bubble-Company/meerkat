<% content_for :title, @page[:title] %>
<% content_for :meta_description, @page[:description] %>
<% content_for :og_title, @page[:og_title] %>
<% content_for :og_description, @page[:og_description] %>
<% content_for :og_type, "article" %>
<% content_for :canonical_url, marketing_canonical_url(request.path) %>

<% content_for :head do %>
  <script type="application/ld+json"><%= faq_json_ld(@page[:faqs]) %></script>
<% end %>

<%= render "marketing/site_nav" %>

<section class="relative isolate overflow-hidden border-b border-border">
  <div class="absolute inset-0 bg-grid opacity-30"></div>
  <div class="absolute inset-0" style="background: var(--gradient-glow)"></div>
  <div class="relative mx-auto max-w-5xl px-6 pt-20 pb-20 lg:pt-28">
    <p class="font-mono text-[11px] uppercase tracking-[0.3em] text-primary"><%= @page[:eyebrow] %></p>
    <h1 class="mt-6 font-serif text-[clamp(2rem,5vw,3.75rem)] font-normal leading-[1.05] tracking-[-0.02em] text-balance">
      <%= @page[:headline] %>
      <% if @page[:headline_italic].present? %>
        <span class="italic text-muted-foreground"><%= @page[:headline_italic] %></span>
      <% end %>
    </h1>
    <p class="mt-6 max-w-2xl text-[17px] leading-relaxed text-muted-foreground"><%= @page[:intro] %></p>
    <div class="mt-8 flex flex-wrap items-center gap-3">
      <%= link_to marketing_signup_label, marketing_signup_path, class: "bg-primary px-5 py-3 font-mono text-[13px] font-semibold uppercase tracking-wider text-primary-foreground transition hover:brightness-110" %>
      <%= link_to "Read docs", marketing_docs_path, class: "border border-border bg-card/60 px-5 py-3 font-mono text-[13px] font-semibold uppercase tracking-wider text-foreground transition hover:border-primary/50" %>
      <%= link_to "Quickstart →", marketing_docs_section_path("quickstart"), class: "border border-border bg-card/60 px-5 py-3 font-mono text-[13px] font-semibold uppercase tracking-wider text-foreground transition hover:border-primary/50" %>
    </div>
  </div>
</section>

<section class="border-b border-border py-20">
  <div class="mx-auto grid max-w-5xl gap-10 px-6 md:grid-cols-2">
    <% @page[:bullets].each do |bullet| %>
      <div>
        <h2 class="font-serif text-2xl tracking-tight"><%= bullet[:title] %></h2>
        <p class="mt-3 text-[15px] leading-relaxed text-muted-foreground"><%= bullet[:body] %></p>
      </div>
    <% end %>
  </div>
</section>

<section class="border-b border-border py-20">
  <div class="mx-auto max-w-5xl px-6">
    <p class="font-mono text-[11px] uppercase tracking-[0.3em] text-primary">Example request</p>
    <h2 class="mt-4 font-serif text-3xl tracking-tight">POST /api/v1/tasks</h2>
    <pre class="mt-6 overflow-x-auto rounded-xl border border-border bg-card p-6 font-mono text-[12.5px] leading-relaxed text-foreground/90"><%= @page[:code].strip %></pre>
    <div class="mt-6 flex flex-wrap gap-3">
      <%= link_to "Create account →", marketing_signup_path, class: "rounded-md bg-primary px-4 py-2.5 font-mono text-[12px] font-semibold uppercase tracking-wider text-primary-foreground transition hover:brightness-110" %>
      <%= link_to "Task types docs", marketing_docs_section_path("task-types"), class: "rounded-md border border-border bg-card px-4 py-2.5 font-mono text-[12px] uppercase tracking-widest transition hover:border-primary/40" %>
    </div>
  </div>
</section>

<section class="border-b border-border py-20">
  <div class="mx-auto max-w-3xl px-6">
    <p class="font-mono text-[11px] uppercase tracking-[0.3em] text-primary">FAQ</p>
    <h2 class="mt-4 font-serif text-3xl tracking-tight">Common questions</h2>
    <div class="mt-8 divide-y divide-border border-y border-border">
      <% @page[:faqs].each do |faq| %>
        <div class="py-5">
          <h3 class="font-serif text-lg"><%= faq[:q] %></h3>
          <p class="mt-2 text-[15px] leading-relaxed text-muted-foreground"><%= faq[:a] %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>

<section class="border-b border-border py-16">
  <div class="mx-auto max-w-5xl px-6 text-center">
    <h2 class="font-serif text-3xl tracking-tight">Ready to ship your first webhook?</h2>
    <p class="mx-auto mt-4 max-w-xl text-muted-foreground">Sign up, connect your LLM key in onboarding, and register a task in under five minutes.</p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <%= link_to marketing_signup_label, marketing_signup_path, class: "rounded-md bg-primary px-6 py-3 font-mono text-sm font-semibold text-primary-foreground transition hover:brightness-110 glow-amber" %>
      <%= link_to "Self-host on GitHub", github_repo_url, class: "rounded-md border border-border bg-card px-6 py-3 font-mono text-sm font-semibold transition hover:border-primary/40", target: "_blank", rel: "noopener" %>
    </div>
  </div>
</section>

<footer class="py-12">
  <div class="mx-auto flex max-w-5xl flex-wrap items-center justify-between gap-4 px-6 font-mono text-[11px] uppercase tracking-[0.25em] text-muted-foreground">
    <span>© Meerkat · MIT licensed</span>
    <div class="flex gap-6">
      <%= link_to "GitHub", github_repo_url, class: "hover:text-foreground", target: "_blank", rel: "noopener" %>
      <%= link_to "Docs", marketing_docs_path, class: "hover:text-foreground" %>
      <%= link_to "Sign up", marketing_signup_path, class: "hover:text-foreground" %>
    </div>
  </div>
</footer>
