# Rails Agent — marketing site
rails-agent.com, www.rails-agent.com {
	encode gzip zstd
	reverse_proxy rails-agents-cloud:3000
}

# Rails Agent — cloud API + dashboard (same Next.js app)
cloud.rails-agent.com {
	encode gzip zstd
	reverse_proxy rails-agents-cloud:3000
}

# Rails Agent — internal ops portal
ops.rails-agent.com {
	encode gzip zstd
	reverse_proxy rails-agents-ops:3000
}

# Legacy Rails Agent hosts → new domain
meerkatagents.com, www.meerkatagents.com {
	encode gzip zstd
	redir https://rails-agent.com{uri} permanent
}

rails.meerkatagents.com {
	encode gzip zstd
	redir https://rails-agent.com/docs permanent
}

agents.meerkatagents.com {
	encode gzip zstd
	redir https://rails-agent.com{uri} permanent
}

ops.meerkatagents.com {
	encode gzip zstd
	redir https://ops.rails-agent.com{uri} permanent
}

# Meerkat product cloud (unchanged)
cloud.meerkatagents.com {
	encode gzip zstd
	handle_path /ra/* {
		redir https://rails-agent.com{uri} permanent
	}
	redir /ra https://rails-agent.com/ permanent
	handle {
		reverse_proxy web:80
	}
}
