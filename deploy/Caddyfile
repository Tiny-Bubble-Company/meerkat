meerkatagents.com, www.meerkatagents.com {
	encode gzip zstd
	reverse_proxy rails-agents-cloud:3000
}

# Legacy Rails Agents docs host → new site docs
rails.meerkatagents.com {
	encode gzip zstd
	redir https://meerkatagents.com/docs permanent
}

# Optional: keep agents. subdomain pointing at same Next app (or redirect to apex)
agents.meerkatagents.com {
	encode gzip zstd
	redir https://meerkatagents.com{uri} permanent
}

cloud.meerkatagents.com {
	encode gzip zstd
	handle_path /ra/* {
		redir https://meerkatagents.com{uri} permanent
	}
	redir /ra https://meerkatagents.com/ permanent
	handle {
		reverse_proxy web:80
	}
}

ops.meerkatagents.com {
	encode gzip zstd
	reverse_proxy web:80
}
