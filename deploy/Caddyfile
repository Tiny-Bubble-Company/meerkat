meerkatagents.com, www.meerkatagents.com {
	encode gzip zstd

	@rails path /docs* /signup /login /onboarding* /api/* /up
	handle @rails {
		reverse_proxy web:80
	}

	handle {
		reverse_proxy website:3000
	}
}

cloud.meerkatagents.com {
	encode gzip zstd

	# Legacy /ra path → agents dashboard host (strip /ra prefix)
	handle_path /ra/* {
		redir https://agents.meerkatagents.com{uri} permanent
	}
	redir /ra https://agents.meerkatagents.com/ permanent

	handle {
		reverse_proxy web:80
	}
}

ops.meerkatagents.com {
	encode gzip zstd
	reverse_proxy web:80
}

# Rails Agents Cloud — dashboard + API
agents.meerkatagents.com {
	encode gzip zstd
	reverse_proxy rails-agents-cloud:3000
}

# Rails Agents gem homepage + docs (VitePress)
rails.meerkatagents.com {
	encode gzip zstd
	reverse_proxy rails-agents-docs:80
}
