meerkatagents.com, www.meerkatagents.com {
	encode gzip zstd

	@rails path /docs* /signup /login /onboarding* /api/* /up
	handle @rails {
		reverse_proxy web:80
	}

	handle {
		reverse_proxy website:3000
	}
}

cloud.meerkatagents.com, ops.meerkatagents.com {
	encode gzip zstd
	reverse_proxy web:80
}

# Rails Agents Cloud — sibling app on same Hetzner VPS
# Container from /opt/meerkat-apps/rails-agents-cloud compose project
agents.meerkatagents.com {
	encode gzip zstd
	# rails-agents-cloud publishes 127.0.0.1:3010; Docker bridge gateway reaches host
	reverse_proxy 172.17.0.1:3010
}
