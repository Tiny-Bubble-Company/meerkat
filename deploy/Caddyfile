meerkatagents.com, www.meerkatagents.com {
	encode gzip zstd

	@rails path /docs* /signup /login /onboarding* /api/* /up
	handle @rails {
		reverse_proxy web:80
	}

	handle {
		reverse_proxy website:3000
	}
}

cloud.meerkatagents.com {
	encode gzip zstd

	# Rails Agents Cloud (live now — no extra DNS required)
	# https://cloud.meerkatagents.com/ra/
	handle_path /ra/* {
		reverse_proxy rails-agents-cloud:3000
	}

	handle {
		reverse_proxy web:80
	}
}

ops.meerkatagents.com {
	encode gzip zstd
	reverse_proxy web:80
}

# Preferred host once DNS A record exists (GoDaddy → 167.233.121.12)
agents.meerkatagents.com {
	encode gzip zstd
	reverse_proxy rails-agents-cloud:3000
}
